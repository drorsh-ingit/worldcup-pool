generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ───

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships       GroupMembership[]
  bets              Bet[]
  pushSubscriptions PushSubscription[]

  @@map("users")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

// ─── GROUPS ───

model Group {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  settings  Json     @default("{}")  // All configurable weights, thresholds, multipliers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members     GroupMembership[]
  tournaments Tournament[]

  @@map("groups")
}

model GroupMembership {
  id       String           @id @default(cuid())
  userId   String
  groupId  String
  role     MemberRole       @default(MEMBER)
  status   MembershipStatus @default(PENDING)
  joinedAt DateTime         @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@map("group_memberships")
}

enum MemberRole {
  ADMIN
  MEMBER
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
}

// ─── TOURNAMENT ───

model Tournament {
  id        String           @id @default(cuid())
  groupId   String
  kind      String           @default("WC_2026") // TournamentProfile id — see src/lib/tournaments/registry.ts
  name      String           @default("FIFA World Cup 2026")
  status    TournamentStatus @default(SETUP)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  teams    Team[]
  matches  Match[]
  betTypes BetType[]
  bets     Bet[]

  @@map("tournaments")
}

enum TournamentStatus {
  SETUP
  GROUP_STAGE
  KNOCKOUT
  COMPLETE
}

// ─── TEAMS ───

model Team {
  id           String @id @default(cuid())
  tournamentId String
  name         String
  code         String // e.g., "BRA", "MAR"
  groupLetter  String // e.g., "A", "B", ..., "L"
  odds         Json   @default("{}") // { winnerOdds, groupWinnerOdds, qualifyOdds, ... }

  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeMatches Match[]    @relation("HomeTeam")
  awayMatches Match[]    @relation("AwayTeam")

  @@unique([tournamentId, code])
  @@map("teams")
}

// ─── MATCHES ───

model Match {
  id             String      @id @default(cuid())
  tournamentId   String
  homeTeamId     String
  awayTeamId     String
  phase          MatchPhase
  matchday       Int         @default(1) // 1,2,3 for group stage
  groupLetter    String?     // null for knockout matches
  kickoffAt      DateTime
  actualHomeScore Int?
  actualAwayScore Int?
  status         MatchStatus @default(UPCOMING)
  oddsData       Json        @default("{}") // { homeWin, draw, awayWin, correctScores: {...} }
  multiplier     Float       @default(1.0)  // knockout multiplier
  externalId     String?                    // football-data.org match ID for live scores

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam   Team       @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team       @relation("AwayTeam", fields: [awayTeamId], references: [id])
  bets       Bet[]

  @@map("matches")
}

enum MatchPhase {
  GROUP
  R32
  R16
  QF
  SF
  FINAL
}

enum MatchStatus {
  UPCOMING
  LOCKED    // Bets are closed, match about to start or in progress
  COMPLETED // Result entered
}

// ─── BET TYPES ───

model BetType {
  id           String           @id @default(cuid())
  tournamentId String
  category     BetCategory
  subType      String           // e.g., "winner", "runner_up", "boot", "grpwin", "match_score", etc.
  name         String           // Display name
  description  String?
  config       Json             @default("{}") // { options, odds, subWeight, basePct, outlierThreshold, ... }
  openTrigger  BetOpenTrigger?  // When tournament bets become available (null for PER_GAME/CURATED)
  opensAt      DateTime?
  locksAt      DateTime?
  resolvedAt   DateTime?
  resolution   Json?            // The correct answer(s) once resolved
  status       BetTypeStatus    @default(DRAFT)
  frozenOdds   Json?            // Snapshot of relevant odds at the moment this bet type opened.
                                // For tournament bets: { teams: { CODE: { winnerOdds, groupWinnerOdds, qualifyOdds } } }
                                // Null until openBetType runs. Reads fall back to live Team.odds when null.

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  bets       Bet[]

  @@map("bet_types")
}

enum BetCategory {
  TOURNAMENT
  PER_GAME
  CURATED
}

enum BetOpenTrigger {
  PRE_TOURNAMENT
  AFTER_GROUP_STAGE
  AFTER_R32
  AFTER_R16
  AFTER_QF
  AFTER_SF
}

enum BetTypeStatus {
  DRAFT
  OPEN
  LOCKED
  RESOLVED
}

// ─── BETS ───

model Bet {
  id           String   @id @default(cuid())
  userId       String
  tournamentId String
  betTypeId    String
  matchId      String?  // Only for per-game and curated bets
  prediction   Json     // Flexible: { team: "BRA" } or { homeScore: 2, awayScore: 1 } or { player: "Mbappe" }
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Scoring results (populated when bet is resolved)
  isCorrect    Boolean?
  basePoints   Float?
  bonusPoints  Float?
  totalPoints  Float?
  scoredAt     DateTime?

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  betType    BetType    @relation(fields: [betTypeId], references: [id], onDelete: Cascade)
  match      Match?     @relation(fields: [matchId], references: [id])

  @@unique([userId, betTypeId, matchId]) // One bet per user per bet type per match
  @@map("bets")
}

// ─── LEADERBOARD (cached) ───

model LeaderboardEntry {
  id              String   @id @default(cuid())
  userId          String
  groupId         String
  tournamentId    String
  totalPoints     Float    @default(0)
  rank            Int      @default(0)
  tournamentPts   Float    @default(0)
  perGamePts      Float    @default(0)
  curatedPts      Float    @default(0)
  correctBets     Int      @default(0)
  totalBets       Int      @default(0)
  updatedAt       DateTime @updatedAt

  @@unique([userId, groupId, tournamentId])
  @@map("leaderboard")
}
